{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "addLabels": [
    "renovate",
    "{{{manager}}}"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        "^README.md$"
      ],
      "matchStrings": [
        "(?<depName>[\\w/\\.]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
